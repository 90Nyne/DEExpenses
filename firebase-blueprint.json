{
  "entities": {
    "User": {
      "title": "User Profile & Settings",
      "description": "User specific configuration and metadata.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "currency": { "type": "string", "enum": ["GHS", "USD", "EUR", "GBP", "JPY"] },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "currency", "theme", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction Record",
      "description": "A single financial transaction (income or expense).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "categoryId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "categoryId", "date", "createdAt", "updatedAt"]
    },
    "Category": {
      "title": "Expense Category",
      "description": "A category for grouping transactions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "icon", "color", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User settings and profile."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User's financial transactions."
    },
    "/users/{userId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "User's custom categories."
    }
  }
}
